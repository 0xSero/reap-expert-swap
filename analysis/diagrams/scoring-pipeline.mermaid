%%{init: {'theme': 'dark'}}%%
flowchart TD
    P["prompt_text"] --> N["normalize + tokenize"]
    P --> T["infer_domain_tags()"]
    BM["benchmark name"] --> T
    N --> RT["routing_text"]
    T --> TAGS["tags: code, math, writing, ..."]

    subgraph PerLayer["Per Layer (×40)"]
        direction TB
        AM["activationMass<br/>(static from plan)"]

        subgraph ClusterBoost["Cluster Prior Boost"]
            CP["cluster_priors[tag][layer]"]
            CB["+ AM × 0.15 per matching tag"]
            CP --> CB
        end

        subgraph TaskBoost["TaskFamily Prior Boost"]
            TF["priors[tag][layer]"]
            TB2["+ taskPriors[tag] × 0.25"]
            TF --> TB2
        end

        subgraph SupportBoost["Support Boosts (mode != none)"]
            BMP["benchmarkMissPriors"]
            TMP["tagMissPriors"]
            LEX["lexicalMissExemplars"]
            BMS["+ prior_mass × LAS × 20"]
            TMS["+ prior_mass × LAS × 8"]
            LES["+ lexical_mass × LAS × scale"]
            BMP --> BMS
            TMP --> TMS
            LEX --> LES
        end

        subgraph EmergencyBoost["Router Miss Boost"]
            RM["router_misses"]
            RMB["+ 1000 per missed expert"]
            RM --> RMB
        end

        AM --> BASE["base_score"]
        CB --> BASE
        TB2 --> BASE
        RMB --> BASE

        BASE --> SUP["support_score = base + support boosts"]
        BMS --> SUP
        TMS --> SUP
        LES --> SUP
    end

    subgraph Rotation["Rotation (policy = late_prompt_hash)"]
        RW["rotation_window = min(max(2, cand_target), 4)"]
        RO["offset = (semantic + sha1(layer|prompt)) % window"]
        PERM["circular permute top-N window"]
        RW --> RO --> PERM
    end

    subgraph Assembly["assemble_active_set()"]
        CORE["core experts (always resident)"]
        SEL["greedy first-fit: top slices within budget"]
        SIG2["compute_active_set_signature()"]
        CORE --> ACT["active_set = core ∪ selected slices"]
        SEL --> ACT --> SIG2
    end

    TAGS --> ClusterBoost
    TAGS --> TaskBoost
    RT --> SupportBoost

    SUP --> Rotation
    BASE --> Rotation
    Rotation --> Assembly

    style SupportBoost fill:#4a1a1a,stroke:#ff4444
    style ClusterBoost fill:#1a3a1a,stroke:#44ff44
    style TaskBoost fill:#1a1a3a,stroke:#4444ff
    style EmergencyBoost fill:#3a3a1a,stroke:#ffff44
